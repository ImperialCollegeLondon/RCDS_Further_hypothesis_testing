x <- rbinom(n, 1, 0.5)
sample_mean[i] <- mean(x)
std_sample_mean[i] <- sqrt(n) * (mean(x) - 0.5) / 0.5
}
# Histogram of mean values
hist(std_sample_mean,
col = "steelblue",
freq = FALSE,
breaks = 40,
xlim = c(-3, 3),
ylim = c(0, 0.8),
xlab = paste("n =", n),
main = "")
# Overlay normal distribution N(0,1)
curve(dnorm(x),
lwd = 2,
col = "darkred",
add = TRUE)
